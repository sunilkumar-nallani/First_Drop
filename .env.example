# =============================================================================
# FirstDrop Environment Variables
# =============================================================================
# Copy this file to .env.local for local development
# For production, set these in your Vercel dashboard
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?PARAMS
# 
# For local development (using local PostgreSQL):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/firstdrop?schema=public"
#
# For Neon (production): Get this from your Neon dashboard
# DATABASE_URL="postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/firstdrop?sslmode=require&connection_limit=1"
#
# For Supabase (alternative): Get this from your Supabase dashboard
# DATABASE_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres?sslmode=require&connection_limit=1"

# -----------------------------------------------------------------------------
# NextAuth.js Configuration
# -----------------------------------------------------------------------------
# Random string used to hash tokens, sign cookies and generate cryptographic keys
# Generate with: openssl rand -base64 32
# Or use: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="your-super-secret-random-string-min-32-characters-long"

# The canonical URL of your site
# For local development:
NEXTAUTH_URL="http://localhost:3000"
# For production (after deploying to Vercel):
# NEXTAUTH_URL="https://your-domain.vercel.app"
# Or with custom domain:
# NEXTAUTH_URL="https://firstdrop.io"

# -----------------------------------------------------------------------------
# Email Configuration (Resend)
# -----------------------------------------------------------------------------
# Get your API key from: https://resend.com/api-keys
# Free tier includes 3,000 emails/month
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# The "from" address for emails
# Must be a verified domain in Resend
RESEND_FROM_EMAIL="notifications@yourdomain.com"
# For testing without a verified domain, use:
# RESEND_FROM_EMAIL="onboarding@resend.dev"

# -----------------------------------------------------------------------------
# Optional: App Configuration
# -----------------------------------------------------------------------------
# Node environment (set automatically by Vercel)
NODE_ENV="development"
# NODE_ENV="production"
